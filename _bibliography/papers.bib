@article{silvestri_pecnik_2021,
  bibtex_show = {true},
  selected    = {true},
  title       = {Turbulence modulation in thermally expanding and contracting flows},
  volume      = {926},
  doi         = {10.1017/jfm.2021.726},
  journal     = {Journal of Fluid Mechanics},
  author      = {Simone Silvestri and Rene Pecnik},
  year        = {2021},
  pages       = {A30},
  pdf         = {art-jfm-21.pdf},
  altmetric   = {248277},
  dimensions  = {true},
  abstract    = {We use direct numerical simulations to investigate how turbulence is modulated in heated and cooled channel flows with large temperature-dependent variations of density and viscosity. We show that the semi-local scaling framework, which accounts for local mean property variations, successfully collapses the first- and second-order turbulence statistics across a wide range of thermodynamic conditions. The analysis reveals that thermal expansion and contraction of the fluid create asymmetric turbulence modulation between the hot and cold walls.}
}

@article{SILVESTRI2021108728,
  bibtex_show = {true},
  title   = {Modelling turbulent heat flux accounting for Turbulence-Radiation Interactions},
  journal = {International Journal of Heat and Fluid Flow},
  volume  = {89},
  pages   = {108728},
  year    = {2021},
  issn    = {0142-727X},
  doi     = {https://doi.org/10.1016/j.ijheatfluidflow.2020.108728},
  author  = {Simone Silvestri and Dirk J.E.M. Roekaerts and Rene Pecnik},
  pdf     = {art-ijhff-21.pdf},
  abstract = {We investigate the modelling of turbulent heat flux in participating media where turbulence-radiation interactions (TRI) play a significant role. Using data from Direct Numerical Simulations of turbulent channel flows with radiative heat transfer, we assess the performance of standard gradient-diffusion models for the turbulent heat flux and propose corrections that account for the effects of TRI on the temperature variance and turbulent Prandtl number.}
}

@book{bookchapter,
